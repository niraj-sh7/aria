# ARIA Environment Configuration

# Backend selection: "ollama" (local, free) or "openrouter" (cloud, paid)
ARIA_BACKEND=ollama

# Required only when ARIA_BACKEND=openrouter
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: override default model for OpenRouter
# Default: google/gemma-2-27b-it
# Fast fallback: google/gemini-flash-2.0
# Complex: anthropic/claude-haiku-3
OPENROUTER_MODEL=google/gemma-4-31b-it:free
